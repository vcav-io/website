---
// StatusMap.astro
// What Exists Today — simple status list
---

<section class="section section--alt reveal" id="status">
  <div class="container">
    <div class="status-map">
      <h2 class="status-map__title">What Exists Today</h2>

      <ul class="status-map__list">
        <li>Protocol specification &mdash; <span class="status-map__available">available</span></li>
        <li>Software relay &mdash; <span class="status-map__available">available</span></li>
        <li>Receipt verification &mdash; <span class="status-map__available">available</span></li>
        <li>Demo UI &mdash; <span class="status-map__available">available</span></li>
        <li>Artefact registry and contract builder &mdash; <span class="status-map__available">available</span></li>
        <li>TypeScript client and MCP server &mdash; <span class="status-map__available">available</span></li>
        <li>TEE execution lane &mdash; <span class="status-map__progress">hardware validated, integration in progress</span></li>
        <li>VCAV high-assurance tier &mdash; <span class="status-map__planned">in development</span></li>
      </ul>
    </div>
  </div>
</section>

<style>
  .status-map {
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .status-map__title {
    margin-bottom: var(--space-lg);
  }

  .status-map__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .status-map__list li {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .status-map__available {
    color: var(--color-success);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .status-map__progress {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .status-map__planned {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
</style>
