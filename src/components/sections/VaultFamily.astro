---
// VaultFamily.astro
// Three components: AgentVault (primary), VFC (neutral), VCAV (muted)
import AVMark from '../icons/AVMark.astro';
import VCAVMark from '../icons/VCAVMark.astro';
---

<section class="section section--alt reveal" id="family">
  <div class="container">
    <h2>Execution Lanes and Trust Boundaries</h2>
    <p class="intro">
      AgentVault runs in two execution lanes. In the <strong>software lane</strong>,
      the relay operator can see your data — you trust them the way you trust any
      SaaS provider. In the <strong>TEE lane</strong>, coordination runs inside
      hardware-isolated memory that the operator cannot read, even with root access.
      Same protocol, same receipts — the difference is who can see your plaintext.
    </p>
    <p class="intro intro--paired">
      VCAV goes further: local models, hardware attestation, and side-channel
      hardening shrink the trust boundary to the sealed VM itself.
    </p>

    <div class="cards">
      <div class="card card--primary">
        <div class="card__header">
          <div class="card__name-row">
            <AVMark class="card__icon" />
            <h3 class="card__name">AgentVault</h3>
          </div>
          <a
            href="https://github.com/vcav-io/agentvault"
            class="card__link"
            target="_blank"
            rel="noopener noreferrer"
          >vcav-io/agentvault</a>
        </div>
        <p class="card__description">
          The open protocol for private, verifiable agent-to-agent coordination.
          Two execution lanes: a software lane (operator-attested) and a TEE lane
          (hardware-assured, operator excluded from plaintext). Relay-enforced
          contracts composed from a content-addressed artefact ecosystem,
          schema-bound outputs, and cryptographic receipts.
        </p>
        <div class="card__tag card__tag--primary">Software + TEE execution lanes</div>
      </div>

      <div class="card">
        <div class="card__header">
          <div class="card__name-row">
            <VCAVMark class="card__icon" />
            <h3 class="card__name">VCAV</h3>
          </div>
          <span class="card__badge">Private — hardware validated</span>
        </div>
        <p class="card__description">
          The highest assurance tier — local models, hardware attestation (AMD SEV-SNP,
          validated on GCP N2D), and side-channel hardening shrink the trust envelope
          to the sealed VM itself. A dedicated orchestrator enforces information flow
          control and privacy budgets. Same bounded-disclosure principle, strongest
          guarantees.
        </p>
        <div class="card__tag">Confidential coordination infrastructure</div>
      </div>

      <div class="card">
        <div class="card__header">
          <h3 class="card__name">VFC — Vault Family Core</h3>
          <a
            href="https://github.com/vcav-io/vault-family-core"
            class="card__link"
            target="_blank"
            rel="noopener noreferrer"
          >vcav-io/vault-family-core</a>
        </div>
        <p class="card__description">
          Receipt envelope, cryptographic primitives, AFAL wire types, and
          interoperability semantics. Ensures that receipts issued in one lane
          verify in another.
        </p>
        <div class="card__tag">Shared foundation</div>
      </div>
    </div>

    <p class="disambiguation text-dim">
      Not affiliated with other projects using the AgentVault name.
      All packages use the <code>vcav-io</code> namespace.
    </p>
  </div>
</section>

<style>
  h2 {
    max-width: var(--content-max);
    margin: 0 auto var(--space-md);
  }

  .intro {
    max-width: var(--content-max);
    margin: 0 auto var(--space-sm);
  }

  .principles {
    margin-bottom: var(--space-sm);
  }

  .intro--paired {
    line-height: var(--leading-normal);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .card {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: transform 300ms var(--ease-out),
                border-color 300ms var(--ease-out),
                box-shadow 300ms var(--ease-out);
  }

  .card:not(.card--muted):hover {
    transform: translateY(-2px);
    border-color: var(--color-border);
  }

  .card--primary {
    border-color: var(--color-vault-border);
    background: var(--color-vault-bg);
    box-shadow: 0 0 40px var(--color-vault-glow);
  }

  .card--primary:hover {
    box-shadow: 0 0 60px var(--color-vault-glow), 0 4px 20px rgba(0, 0, 0, 0.3);
    border-color: var(--color-accent-dim);
  }

  .card--muted {
    opacity: 0.6;
    border-style: dashed;
  }

  .card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .card__name-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  :global(.card__icon) {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-text-secondary);
  }

  .card--primary :global(.card__icon) {
    color: var(--color-accent);
  }

  .card--muted :global(.card__icon) {
    color: var(--color-text-dim);
  }

  .card__name {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
  }

  .card--muted .card__name {
    color: var(--color-text-secondary);
  }

  .card__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  .card__link--muted {
    color: var(--color-text-dim);
  }

  .card__badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.15em 0.5em;
    display: inline-block;
    width: fit-content;
  }

  .card__description {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    flex: 1;
    max-width: none;
  }

  .card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    border: 1px solid var(--color-border-subtle);
    border-radius: 3px;
    padding: 0.2em 0.5em;
    display: inline-block;
    width: fit-content;
  }

  .card__tag--primary {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
  }

  .disambiguation {
    font-size: var(--text-sm);
    max-width: var(--content-max);
    margin: 0 auto;
  }
</style>
